rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /workspace_snapshots/{workspaceId} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'sia.aronietis@example.com'
        && workspaceId == 'webgoalz-brothers';
    }
  }
}
